# .env.example — Canonical list of environment variables this harness reads.
# Copy to .env and fill in real values. NEVER commit .env to version control.

# ─── Anthropic ────────────────────────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── GitHub (used by MCP github server, work-items sync) ─────────────────────
GITHUB_TOKEN=

# ─── Harness-internal overrides (all optional) ────────────────────────────────
# CLAUDE_HOME=/custom/path/to/.claude            # override default ~/.claude
# HARNESS_OBSERVER_DIR=/custom/observer/dir      # override XDG_DATA_HOME default
# HARNESS_HOOK_PROFILE=safe                      # hook profile selector
# HARNESS_DISABLED_HOOKS=hook-name-1,hook-name-2 # comma-separated disable list
# HARNESS_GH_SHIM=1                              # use the gh shim for testing
# HARNESS_SESSION_RECORDING_DIR=/tmp/recordings  # session recording output dir
